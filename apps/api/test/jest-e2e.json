{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(otplib|@otplib|@scure|@noble|uuid)/)"
  ],
  "moduleNameMapper": {
    "^@crm/auth(|/.*)$": "<rootDir>/../../../libs/auth/src/$1",
    "^@crm/companies(|/.*)$": "<rootDir>/../../../libs/companies/src/$1",
    "^@crm/email(|/.*)$": "<rootDir>/../../../libs/email/src/$1",
    "^@crm/notes(|/.*)$": "<rootDir>/../../../libs/notes/src/$1",
    "^@crm/shared(|/.*)$": "<rootDir>/../../../libs/shared/src/$1",
    "^@crm/tasks(|/.*)$": "<rootDir>/../../../libs/tasks/src/$1",
    "^@crm/tenant(|/.*)$": "<rootDir>/../../../libs/tenant/src/$1",
    "^@crm/users(|/.*)$": "<rootDir>/../../../libs/users/src/$1",
    "^@crm/automation(|/.*)$": "<rootDir>/../../../libs/automation/src/$1",
    "^@crm/audit(|/.*)$": "<rootDir>/../../../libs/audit/src/$1",
    "^@crm/campaigns(|/.*)$": "<rootDir>/../../../libs/campaigns/src/$1",
    "^@crm/marketing-campaigns(|/.*)$": "<rootDir>/../../../libs/marketing-campaigns/src/$1",
    "^@crm/sales-goals(|/.*)$": "<rootDir>/../../../libs/sales-goals/src/$1",
    "^@crm/lead-forms(|/.*)$": "<rootDir>/../../../libs/lead-forms/src/$1",
    "^@crm/dashboard(|/.*)$": "<rootDir>/../../../libs/dashboard/src/$1",
    "^@crm/products(|/.*)$": "<rootDir>/../../../libs/products/src/$1",
    "^@crm/quotes(|/.*)$": "<rootDir>/../../../libs/quotes/src/$1",
    "^@crm/tickets(|/.*)$": "<rootDir>/../../../libs/tickets/src/$1",
    "^@crm/api-keys(|/.*)$": "<rootDir>/../../../libs/api-keys/src/$1",
    "^@crm/webhooks(|/.*)$": "<rootDir>/../../../libs/webhooks/src/$1",
    "^@crm/whatsapp(|/.*)$": "<rootDir>/../../../libs/whatsapp/src/$1",
    "^@crm/tenant-settings(|/.*)$": "<rootDir>/../../../libs/tenant-settings/src/$1",
    "^@crm/ai-assistant(|/.*)$": "<rootDir>/../../../libs/ai-assistant/src/$1",
