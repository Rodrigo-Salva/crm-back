{
  "name": "crm-back",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "node --max-old-space-size=4096 ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/api/test/jest-e2e.json"
  },
  "prisma": {
    "seed": "ts-node ./prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.23",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.23",
    "@prisma/client": "^5.22.0",
    "@types/mailparser": "^3.4.6",
    "@types/multer": "^2.1.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "csv-parser": "^3.2.1",
    "exceljs": "^4.4.0",
    "googleapis": "^172.0.0",
    "helmet": "^8.1.0",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.11",
    "multer": "^2.1.1",
    "nestjs-pino": "^4.6.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "otplib": "^13.4.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(otplib|@otplib|@scure|@noble|uuid)/)"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@crm/auth(|/.*)$": "<rootDir>/libs/auth/src/$1",
      "^@crm/companies(|/.*)$": "<rootDir>/libs/companies/src/$1",
      "^@crm/email(|/.*)$": "<rootDir>/libs/email/src/$1",
      "^@crm/notes(|/.*)$": "<rootDir>/libs/notes/src/$1",
      "^@crm/shared(|/.*)$": "<rootDir>/libs/shared/src/$1",
      "^@crm/tasks(|/.*)$": "<rootDir>/libs/tasks/src/$1",
      "^@crm/tenant(|/.*)$": "<rootDir>/libs/tenant/src/$1",
      "^@crm/users(|/.*)$": "<rootDir>/libs/users/src/$1",
      "^@crm/automation(|/.*)$": "<rootDir>/libs/automation/src/$1",
      "^@crm/audit(|/.*)$": "<rootDir>/libs/audit/src/$1",
      "^@crm/campaigns(|/.*)$": "<rootDir>/libs/campaigns/src/$1",
      "^@crm/marketing-campaigns(|/.*)$": "<rootDir>/libs/marketing-campaigns/src/$1",
      "^@crm/sales-goals(|/.*)$": "<rootDir>/libs/sales-goals/src/$1",
      "^@crm/lead-forms(|/.*)$": "<rootDir>/libs/lead-forms/src/$1",
      "^@crm/dashboard(|/.*)$": "<rootDir>/libs/dashboard/src/$1",
      "^@crm/products(|/.*)$": "<rootDir>/libs/products/src/$1",
      "^@crm/quotes(|/.*)$": "<rootDir>/libs/quotes/src/$1",
      "^@crm/tickets(|/.*)$": "<rootDir>/libs/tickets/src/$1",
      "^@crm/api-keys(|/.*)$": "<rootDir>/libs/api-keys/src/$1",
      "^@crm/webhooks(|/.*)$": "<rootDir>/libs/webhooks/src/$1",
      "^@crm/whatsapp(|/.*)$": "<rootDir>/libs/whatsapp/src/$1",
      "^@crm/tenant-settings(|/.*)$": "<rootDir>/libs/tenant-settings/src/$1",
      "^@crm/ai-assistant(|/.*)$": "<rootDir>/libs/ai-assistant/src/$1",
      "^@crm/activities(|/.*)$": "<rootDir>/libs/activities/src/$1",
      "^@crm/custom-fields(|/.*)$": "<rootDir>/libs/custom-fields/src/$1",
      "^@crm/leads(|/.*)$": "<rootDir>/libs/leads/src/$1",
      "^@crm/notifications(|/.*)$": "<rootDir>/libs/notifications/src/$1",
      "^@crm/pipeline-stages(|/.*)$": "<rootDir>/libs/pipeline-stages/src/$1",
      "^@crm/role-permissions(|/.*)$": "<rootDir>/libs/role-permissions/src/$1",
      "^@crm/teams(|/.*)$": "<rootDir>/libs/teams/src/$1",
      "^@crm/time-tracking(|/.*)$": "<rootDir>/libs/time-tracking/src/$1",
      "^@crm/uploads(|/.*)$": "<rootDir>/libs/uploads/src/$1",
      "^@crm/payments(|/.*)$": "<rootDir>/libs/payments/src/$1",
      "^@crm/contracts(|/.*)$": "<rootDir>/libs/contracts/src/$1",
      "^@crm/subscriptions(|/.*)$": "<rootDir>/libs/subscriptions/src/$1",
      "^@crm/playbooks(|/.*)$": "<rootDir>/libs/playbooks/src/$1",
      "^@crm/public-api(|/.*)$": "<rootDir>/libs/public-api/src/$1"
    }
  }
}
